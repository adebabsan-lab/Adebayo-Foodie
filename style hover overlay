.container {
  position: relative;
  overflow: hidden;
}

.overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.55);
  color: #ffffff;
  opacity: 0;
  transition: opacity 0.25s ease-in-out;
}

.overlay h3 {
  margin: 0;
  padding: 0 1rem;
  font-size: 1.2rem;
  text-align: center;
}

.container:hover .overlay {
  opacity: 1;
}
